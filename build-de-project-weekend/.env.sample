# ============================================================
#  Retail Analytics DE Project — Environment Configuration
# ============================================================
#
#  HOW TO USE:
#    1. Copy this file:   cp .env.sample .env   (Mac/Linux)
#                         copy .env.sample .env  (Windows)
#    2. Fill in your values in .env
#    3. Never commit .env — it is in .gitignore
#
# ============================================================

# ── PostgreSQL credentials ───────────────────────────────────
DB_USER=postgres
DB_PASS=your_password_here
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres

# ── Java (optional — auto-detected if java is on your PATH) ──
# Only set this if Spark fails with "JAVA_HOME not set".
# Point it to your JDK root folder (the one that contains bin/java).
#
# Windows example:
#   JAVA_HOME=C:\Program Files\Eclipse Adoptium\jdk-11.0.20.8-hotspot
# macOS example:
#   JAVA_HOME=/Library/Java/JavaVirtualMachines/temurin-11.jdk/Contents/Home
# Linux example:
#   JAVA_HOME=/usr/lib/jvm/java-11-openjdk-amd64
#
JAVA_HOME=
